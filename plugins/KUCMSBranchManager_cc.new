void KUCMSBranch::getValue( std::vector<float>& val, uInt index ){

    switch( BranchType ){

        case VVFLOAT  : val = VVFLOATBranch[index]; break;
        default : std::cout << " -- KUCMSBranch " << BranchName << " Error : BranchType mismatch with getValue type!!!! " << std::endl;

    }//<<>>switch( BranchType )

}//<<>>void KUCMSBranch::getValue( std::vector<float> val, uInt index )

