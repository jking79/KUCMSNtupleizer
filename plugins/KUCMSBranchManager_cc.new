float KUCMSBranch::max( std::vector<float> x ){

    float max = x[0];
    for( uInt idx = 0; idx < x.size(); idx++ ) if( x[idx] > max ) max = x[idx];
    return max;

}//<<>>float KUCMSBranch::max( vector<float> x )

uInt KUCMSBranch::leadIdx( std::vector<float> x ){

    uInt maxidx = 0;
    float max = x[0];
    for( uInt idx = 0; idx < x.size(); idx++ ) if( x[idx] > max ){ max = x[idx]; maxidx = idx; }
    return maxidx;

}//<<>>float KUCMSBranch::max( vector<float> x )

uInt KUCMSBranch::subldIdx( std::vector<float> x, uInt ldx ){

    uInt maxidx = 0;
    float max = 0;
    for( uInt idx = 0; idx < x.size(); idx++ ){
        if( idx == ldx ) continue;
        if( x[idx] > max ){ max = x[idx]; maxidx = idx; }
    }//<<>>for( uInt idx = 0; idx < x.size(); idx++ )
    return maxidx;

}//<<>>float KUCMSBranch::max( vector<float> x )

float KUCMSBranch::getMaxValue(){

    switch( BranchType ){

        case VFLOAT : return max( VFLOATBranch ); break;
        case FLOAT  : return FLOATBranch; break;
        default : std::cout << " -- KUCMSBranch " << BranchName << " Error : BranchType mismatch with getMaxValue type!!!! " << std::endl;

    }//<<>>switch( BranchType )

    return -999;

}//<<>>float KUCMSBranch::getMaxValue()

uInt KUCMSBranch::getLeadIndex(){

    switch( BranchType ){

        case VFLOAT : return leadIdx( VFLOATBranch ); break;
        default : std::cout << " -- KUCMSBranch " << BranchName << " Error : BranchType mismatch with getLeadIdx type!!!! " << std::endl;

    }//<<>>switch( BranchType )

    return 0;

}//<<>>float KUCMSBranch::getLeadIdx()

uInt KUCMSBranch::getSubLeadIndex(){

    switch( BranchType ){

        case VFLOAT : {
            uInt ldx = leadIdx( VFLOATBranch );
            return subldIdx( VFLOATBranch, ldx );
        }
        default : std::cout << " -- KUCMSBranch " << BranchName << " Error : BranchType mismatch with getSubldIdx type!!!! " << std::endl;

    }//<<>>switch( BranchType )

    return 0;

}//<<>>float KUCMSBranch::getSubldIdx()

// -----------------------------
// KUCMSBranchManager
// -----------------------------

KUCMSBranchManager::KUCMSBranchManager(){}
KUCMSBranchManager::~KUCMSBranchManager(){}

bool KUCMSBranchManager::valid( std::string key ){

    if( theBranches.find(key) == theBranches.end() ){

        std::cout << " -- KUCMSBranchManager Error: No Such Key : " << key << " !!!!!!!!!!!!!!!!!!!!!!!!!" << std::endl;
        return false;

    } else return true;

}//<<>>bool KUCMSBranchManager::valid( std::string key )

void KUCMSBranchManager::makeBranch( std::string key, std::string name, BType type, std::string doc ){

    KUCMSBranch branch( type, name, doc );
    theBranches[key] = branch;

}//<<>>void KUCMSBranchManager::makeBranch( std::string key, std::string name, BType type, std::string doc )

void KUCMSBranchManager::makeBranch( std::string name, BType type, std::string doc ){

    makeBranch( name, name, type, doc );

}//<<>>void KUCMSBranchManager::makeBranch( std::string name, BType type, std::string doc )

void KUCMSBranchManager::attachBranches( TTree* fOutTree ){

    for( auto & branch : theBranches ){ (branch.second).initBranch(fOutTree); }

}//<<>>void KUCMSBranchManager::attachBranches( TTree* fOutTree )

void KUCMSBranchManager::clearBranches(){ for( auto & branch : theBranches ){ (branch.second).clearBranch();}}

void KUCMSBranchManager::fillBranch( std::string key, std::vector<float> val ){

    if( valid( key ) ) theBranches[key].fillBranch( val );

}//<<>>void KUCMSBranchManager::fillBranch( std::string key, std::vector<float> val )

void KUCMSBranchManager::fillBranch( std::string key, std::vector<uInt> val ){

    if( valid( key ) ) theBranches[key].fillBranch( val );

}//<<>>void KUCMSBranchManager::fillBranch( std::string key, std::vector<uInt> val )

