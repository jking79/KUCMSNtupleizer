}//<<>>void KUCMSBranchManager::fillBranch( std::string key, std::string val )

void KUCMSBranchManager::fillBranch( std::string key, bool val ){

    if( valid( key ) ) theBranches[key].fillBranch( val );

}//<<>>void KUCMSBranchManager::fillBranch( std::string key, bool val )

std::vector<float> KUCMSBranchManager::getVFLOATBranchValue( std::string key, uInt index ){

    return valid( key ) ? theBranches[key].getVFLOATValue( index ) : std::vector<float>(0);

}//<<>>vector<float> KUCMSBranchManager::getVFLOATBranchValue( std::string key, uInt index )

