}//<<>>void KUCMSBranchManager::fillBranch( std::string key, uInt val )

void KUCMSBranchManager::fillBranch( std::string key, int val ){

    if( valid( key ) ) theBranches[key].fillBranch( val );

}//<<>>void KUCMSBranchManager::fillBranch( std::string key, int val )

void KUCMSBranchManager::fillBranch( std::string key, float val ){

